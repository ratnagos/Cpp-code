#include <iostream>
using namespace std;

class Demo 
{
public:
    void add(int a, int b) {
        cout << "Addition of 2 numbers = " << a + b << endl;
    }

    void add(int a, int b, int c) {
        cout << "Addition of 3 numbers = " << a + b + c << endl;
    }
};

int main() 
{
    Demo d;

    d.add(2, 3);
    d.add(2, 3, 4);

    return 0;
}
